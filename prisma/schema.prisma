generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  DRIVER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TripStatus {
  PENDING
  SEARCHING
  PENDING_ACCEPTANCE
  ASSIGNED
  IN_PROGRESS
  ARRIVED
  COMPLETED
  CANCELLED
  SCHEDULED
  DECLINED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

enum DisbursementStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id               String          @id @default(uuid())
  name             String
  email            String          @unique
  phone            String
  passwordHash     String
  role             UserRole
  rating           Float           @default(5.0)
  totalTrips       Int             @default(0)
  avatarUrl        String?
  walletBalance    Float           @default(0)
  isBlocked        Boolean         @default(false)
  isOnline         Boolean         @default(false)
  carType          String?
  carModel         String?
  carYear          String?
  gender           String?
  address          String?
  nationality      String?
  age              String?
  nin              String?
  transmission     String?
  approvalStatus   ApprovalStatus?
  licenseImageUrl  String?
  ninImageUrl      String?
  selfieImageUrl   String?
  backgroundCheckAccepted Boolean  @default(false)
  locationLat      Float?
  locationLng      Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tripsAsOwner     Trip[]          @relation("OwnerTrips")
  tripsAsDriver    Trip[]          @relation("DriverTrips")
  bankName              String?
  bankCode              String?
  accountNumber         String?
  accountName           String?
  monnifySubAccountCode String?
  payouts          Payout[]
  disbursements   Disbursement[]
  fcmToken              String?
  deviceType            String? // e.g., 'ios', 'android'
  auditLogs             AuditLog[]

  @@index([role, isOnline, approvalStatus])
}

model Trip {
  id               String      @id @default(uuid())
  status           TripStatus  @default(PENDING)
  pickupAddress    String
  pickupLat        Float
  pickupLng        Float
  destAddress      String
  destLat          Float
  destLng          Float
  amount           Float
  distanceKm       Float
  commissionAmount Float       @default(0)
  driverEarnings   Float       @default(0)
  commissionPercent Float      @default(25)
  scheduledAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  completedAt      DateTime?
  startedAt        DateTime?
  estimatedMins    Float?
  finalFare        Float? 
  fareBreakdown    Json?
  paymentStatus   PaymentStatus  @default(UNPAID)
  monnifyTxRef    String?        @unique
  paidAt          DateTime?
  owner            User        @relation("OwnerTrips", fields: [ownerId], references: [id])
  ownerId          String
  driver           User?       @relation("DriverTrips", fields: [driverId], references: [id])
  driverId         String?
  payout           Payout?
  paymentRecord   PaymentRecord?
  tripAuditLogs   TripAuditLog[]

  @@index([status, createdAt])
  @@index([ownerId])
  @@index([driverId])
}

model Payout {
  id            String       @id @default(uuid())
  amount        Float
  status        PayoutStatus @default(PENDING)
  bankName      String?
  accountName   String?
  accountNumber String?
  requestedAt   DateTime     @default(now())
  approvedAt    DateTime?
  driver        User         @relation(fields: [driverId], references: [id])
  driverId      String
  trip          Trip?        @relation(fields: [tripId], references: [id])
  tripId        String?      @unique
}

model SystemSettings {
  id          Int      @id @default(1)
  baseFare    Float    @default(500)
  pricePerKm  Float    @default(100)
  timeRate    Float    @default(50)
  commission  Float    @default(25)
  autoApprove Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedById String?
}

model PaymentRecord {
  id              String    @id @default(uuid())
  tripId          String    @unique
  trip            Trip      @relation(fields: [tripId], references: [id])
  totalAmount     Float
  driverAmount    Float
  platformAmount  Float
  monnifyTxRef    String    @unique
  paymentMethod   String?
  paidAt          DateTime
  webhookPayload  Json
  createdAt       DateTime  @default(now())
}

model Disbursement {
  id            String             @id @default(uuid())
  driverId      String
  driver        User               @relation(fields: [driverId], references: [id])
  amount        Float
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  monnifyRef    String?            @unique
  status        DisbursementStatus @default(PENDING)
  requestedAt   DateTime           @default(now())
  completedAt   DateTime?
  webhookPayload Json?
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
}

model TripAuditLog {
  id        String   @id @default(uuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id])
  status    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tripId])
}
